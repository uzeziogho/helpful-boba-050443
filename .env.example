# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# RevenueCat (web)
# Get your web API key from https://app.revenuecat.com → Project → API Keys
# Web keys start with "rcb_"
VITE_REVENUECAT_API_KEY=rcb_...

# RevenueCat Customer Management URL
# Found in https://app.revenuecat.com → Project → Customer Center
VITE_REVENUECAT_MANAGEMENT_URL=https://billing.revenuecat.com/...
